   "cell_type": "code",
   "source": [
    "experiences = {\n",
    "    \"Baseline CNN\": 0.78,   # exemple (78%)\n",
    "    \"Augmentation + callbacks\": 0.82,  # exemple\n",
    "    \"IMG_SIZE=160\": 0.80,   # exemple\n",
    "}\n",
    "\n",
    "# Ligne de référence (modèle de base) à 78%\n",
    "baseline = 0.78\n",
    "\n",
    "# Préparer les données pour le plot\n",
    "names = list(experiences.keys())\n",
    "accs = list(experiences.values())\n",
    "\n",
    "plt.figure(figsize=(10, 5))\n",
    "bars = plt.bar(names, accs, color=\"steelblue\", alpha=0.85)\n",
    "\n",
    "# Ligne horizontale de référence\n",
    "plt.axhline(baseline, color=\"red\", linestyle=\"--\", linewidth=2, label=f\"Référence {baseline*100:.0f}%\")\n",
    "\n",
    "# Afficher la valeur au-dessus de chaque barre\n",
    "for b, a in zip(bars, accs):\n",
    "    plt.text(\n",
    "        b.get_x() + b.get_width() / 2,\n",
    "        a + 0.005,\n",
    "        f\"{a*100:.1f}%\",\n",
    "        ha=\"center\",\n",
    "        va=\"bottom\",\n",
    "        fontsize=10\n",
    "    )\n",
    "\n",
    "plt.ylim(0, 1.0)\n",
    "plt.ylabel(\"Accuracy (jeu de test)\")\n",
    "plt.title(\"Comparaison des expériences (accuracy test)\")\n",
    "plt.xticks(rotation=20, ha=\"right\")\n",
    "plt.grid(axis=\"y\", alpha=0.25)\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
